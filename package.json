{
  "name": "james-lane-assistant",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:functions-allowlist": "vite-node ./scripts/generate-functions-source-allowlist.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:functions": "npm --prefix functions test",
    "verify": "vite-node ./scripts/verify-questions.mjs",
    "setup:browsers": "playwright install chromium",
    "verify:responsive": "node ./scripts/verify-responsive.mjs",
    "verify:all": "npm run build:functions-allowlist && npm run test && npm run test:functions && npm run build && npm run verify && npm run verify:responsive"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "playwright": "^1.61.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.14",
    "vitest": "^2.1.8"
  }
}
